# Graph backend: "neo4j" enables auto-sync and knowledge graph visualization
GRAPH_BACKEND=neo4j

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillsmarketplace

# Builder agent (ADK Python service)
BUILDER_AGENT_URL=http://localhost:8001
# Must match API_KEY in builder-agent/.env (leave empty if auth is disabled)
BUILDER_API_KEY=

# Site branding (overrides site.yaml for client components)
NEXT_PUBLIC_SITE_NAME=Skills Marketplace
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=https://github.com/rrbanda/skill-mp
NEXT_PUBLIC_CLI_PACKAGE=skills-marketplace
