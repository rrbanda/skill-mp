# LLM Configuration
LLM_MODEL=openai/gemini/models/gemini-2.5-flash
LLM_API_BASE=https://your-llm-endpoint/v1
LLM_API_KEY=your-api-key

# Neo4j (same instance as the knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillsmarketplace
NEO4J_DATABASE=neo4j

# Embedding model (local sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_MAX_CHARS=2000
EMBED_SKILL_BODY_MAX_CHARS=3000

# Vector index
VECTOR_INDEX_NAME=skill_embedding_idx
VECTOR_DIMENSIONS=384
VECTOR_SIMILARITY=cosine
VECTOR_SEARCH_TOP_K=5

# Pipeline
MAX_REFINEMENT_ITERATIONS=3
PIPELINE_TIMEOUT_SECONDS=120
SESSION_TTL_SECONDS=3600

# Registry path for saving generated skills
REGISTRY_DIR=../registry

# Git publishing
GIT_REPO_DIR=..
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_PUSH_ENABLED=true
GIT_AUTHOR_NAME=Skill Builder
GIT_AUTHOR_EMAIL=skill-builder@skills-marketplace.dev
GIT_COMMAND_TIMEOUT=30

# Security
API_KEY=
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8001
